# FastAPI 백엔드 주소.
# 웹(npm run web)에서는 localhost로도 되지만, 실기기(Expo Go)에서 테스트할 때는
# 반드시 FastAPI가 떠 있는 PC의 LAN IP로 바꿔야 한다 (localhost는 휴대폰 자기 자신을 가리킴).
EXPO_PUBLIC_API_URL=http://192.168.200.141:8000
# 위 IP는 이 작업을 진행한 PC의 현재 LAN IP다. 다른 PC/네트워크(특히 행사장)에서
# 백엔드를 돌린다면 그 PC의 IP로 바뀌므로, 실행 전 ipconfig(Windows)/ifconfig로 재확인할 것.
